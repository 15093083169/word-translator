{
  "manifest_version": 3,
  "name": "Click Translate",
  "description": "划词翻译：选中文本后使用快捷键或右键菜单，调用 GLM-4-Flash 翻译，弹出深色气泡并提供复制按钮。",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "https://open.bigmodel.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Click Translate",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "translate-selection": {
      "description": "点击后翻译当前选中文本（默认 Alt+Shift+T）",
      "suggested_key": {
        "default": "Alt+Shift+T"
      }
    }
  }
}
